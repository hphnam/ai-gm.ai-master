# apps/web — Next.js browser bundle env
#
# Next.js auto-loads .env from this directory. Production must set these
# in the deploy platform (Vercel project settings).
#
# The api's WEB_ORIGIN allowlist (apps/api) must include NEXT_PUBLIC_WEB_ORIGIN
# for CORS + better-auth trustedOrigins to succeed.

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000
