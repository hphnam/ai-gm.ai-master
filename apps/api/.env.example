# apps/api — NestJS backend env
# Loaded by apps/api/src/load-env.ts (relative to this file).
# In production, the deploy platform should inject these directly.

DATABASE_URL=postgresql://user:password@host:5432/gm_ai
NODE_ENV=development
PORT=3001

# Redis — required by BullMQ for the proactive nudges queue.
# Use rediss:// for TLS (Digital Ocean managed Redis defaults to TLS).
# Set NUDGE_CRON_DISABLED=1 in dev if you want to skip the repeatable nudge job.
REDIS_URL=redis://127.0.0.1:6379
NUDGE_CRON_DISABLED=

ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
REDUCTO_API_KEY=

# Comma-separate for multiple origins. Used for CORS + better-auth trustedOrigins.
WEB_ORIGIN=http://localhost:3000

# Auth
# Generate: `openssl rand -hex 32`. Must be exactly 64 hex chars.
BETTER_AUTH_SECRET=<generate-with-openssl-rand-hex-32>
BETTER_AUTH_URL=http://localhost:3001

# Email (optional — omit for dev console fallback)
RESEND_API_KEY=
# Required when RESEND_API_KEY is set. Format: "Name <addr@domain>".
MAIL_FROM="GM AI <onboarding@example.dev>"
# Set to "console" to force console mode. Used by probe-auth.ts.
MAIL_DRIVER_OVERRIDE=

# WhatsApp + SMS OTP (Infobip — all SMS goes through Infobip 2FA as of Plan 03-05)
INFOBIP_BASE_URL=
INFOBIP_API_KEY=
INFOBIP_WHATSAPP_SENDER=
# Driver for WhatsApp (scope: WhatsApp adapter only): "console" (dev default), "live", or "disabled" (kill-switch).
INFOBIP_DRIVER_OVERRIDE=console
INFOBIP_WEBHOOK_SECRET=

# Infobip 2FA — SMS OTP (Plan 03-05). Create Application + SMS Message Template on Infobip Portal,
# then paste IDs here. Both required together, or both absent for console fallback.
INFOBIP_2FA_APPLICATION_ID=
INFOBIP_2FA_MESSAGE_ID=
# Driver for phone verification (scope: SMS OTP only): "console" (deterministic PROBE-* codes), "live", or "disabled" (kill-switch → 503).
PHONE_VERIFY_DRIVER_OVERRIDE=console
