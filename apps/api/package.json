{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/main",
    "start:prod": "prisma migrate deploy && node dist/src/main",
    "swagger:generate": "nest build && node dist/src/generate-swagger.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "probe:section": "tsx scripts/probe-section.ts",
    "probe:eval": "tsx scripts/probe-eval.ts",
    "probe:tabular": "tsx scripts/probe-tabular.ts",
    "probe:chat-core": "tsx scripts/probe-chat-core.ts",
    "probe:chat-core:real": "PROBE_CHAT_CORE_REAL=1 tsx scripts/probe-chat-core.ts",
    "probe:whatsapp-onboarding": "PROBE_INFOBIP_STUB=1 tsx scripts/probe-whatsapp-onboarding.ts",
    "test:cost-tracker": "node --import tsx --test src/modules/chat-core/cost-tracker.service.spec.ts",
    "backfill:sections": "tsx scripts/backfill-knowledge-sections.ts",
    "reembed:corpus": "tsx scripts/reembed-corpus.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@anthropic-ai/sdk": "latest",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "@socket.io/redis-adapter": "^8.3.0",
    "ai": "^6.0.168",
    "better-auth": "^1.6.5",
    "bullmq": "^5.76.2",
    "chardet": "^2.1.1",
    "dotenv": "latest",
    "express": "latest",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.10.1",
    "kysely": "^0.28.16",
    "multer": "latest",
    "nest-commander": "latest",
    "nestjs-zod": "^5.3.0",
    "pg": "latest",
    "prisma": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "socket.io": "^4.8.3",
    "square": "^44.0.1",
    "voyageai": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@nestjs/cli": "latest",
    "@swc/cli": "latest",
    "@swc/core": "latest",
    "@types/express": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
